<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rc_call_log_form" model="ir.ui.view">
        <field name="name">rc.call.log.form</field>
        <field name="model">rc.call.log</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_create_ticket" string="Create Ticket"
                            type="object" class="btn-primary"
                            invisible="ticket_id != 0"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,processing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Call Details">
                            <field name="direction"/>
                            <field name="caller_number"/>
                            <field name="callee_number"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="duration_display"/>
                            <field name="user_id"/>
                        </group>
                        <group string="Matching">
                            <field name="partner_id"/>
                            <field name="ticket_ref"/>
                            <field name="rc_call_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Recording">
                            <group>
                                <field name="has_recording"/>
                                <field name="recording_attachment_id"/>
                                <field name="recording_url" widget="url"/>
                            </group>
                        </page>
                        <page string="Transcript">
                            <group>
                                <field name="transcript_attachment_id"/>
                            </group>
                            <field name="transcript" readonly="1"/>
                        </page>
                        <page string="Sentiment">
                            <group>
                                <group string="AI">
                                    <field name="sentiment_score"/>
                                    <field name="sentiment_label"/>
                                    <field name="sentiment_reason"/>
                                </group>
                                <group string="Agent">
                                    <field name="agent_sentiment" widget="radio"/>
                                    <field name="final_sentiment"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                            <field name="error_message" readonly="1" invisible="state != 'failed'"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_rc_call_log_list" model="ir.ui.view">
        <field name="name">rc.call.log.list</field>
        <field name="model">rc.call.log</field>
        <field name="arch" type="xml">
            <list default_order="start_time desc">
                <field name="name"/>
                <field name="start_time"/>
                <field name="direction"/>
                <field name="caller_number"/>
                <field name="partner_id"/>
                <field name="duration_display"/>
                <field name="has_recording"/>
                <field name="final_sentiment"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_rc_call_log_search" model="ir.ui.view">
        <field name="name">rc.call.log.search</field>
        <field name="model">rc.call.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="caller_number"/>
            </search>
        </field>
    </record>

    <record id="action_rc_call_log" model="ir.actions.act_window">
        <field name="name">Call Log</field>
        <field name="res_model">rc.call.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_rc_negative_calls" model="ir.actions.act_window">
        <field name="name">Negative Calls</field>
        <field name="res_model">rc.call.log</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('final_sentiment', '=', 'negative')]</field>
    </record>

    <menuitem id="menu_ringcentral_root" name="RingCentral" sequence="90"/>
    <menuitem id="menu_rc_calls" name="Call Log" parent="menu_ringcentral_root"
              action="action_rc_call_log" sequence="10"/>
    <menuitem id="menu_rc_negative" name="Negative Calls" parent="menu_ringcentral_root"
              action="action_rc_negative_calls" sequence="20"/>
</odoo>
