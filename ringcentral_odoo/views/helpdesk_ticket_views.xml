<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_ticket_form_rc" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.ringcentral</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_calls" type="object" class="oe_stat_button"
                        icon="fa-phone" invisible="rc_call_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value"><field name="rc_call_count"/></span>
                        <span class="o_stat_text">Calls</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//page[last()]" position="after">
                <page string="Call Details" name="rc_call_details" invisible="not rc_call_ref">
                    <field name="rc_escalated" invisible="1"/>
                    <div class="alert alert-warning" role="alert" invisible="not rc_escalated">
                        <strong>This ticket was created/escalated due to negative call sentiment.</strong>
                    </div>
                    <group>
                        <group string="Call Info">
                            <field name="rc_call_ref"/>
                            <field name="rc_direction"/>
                            <field name="rc_caller_number"/>
                            <field name="rc_callee_number"/>
                            <field name="rc_call_duration"/>
                            <field name="rc_call_time"/>
                        </group>
                        <group string="Sentiment">
                            <field name="rc_sentiment"/>
                            <field name="rc_sentiment_score"/>
                            <field name="rc_sentiment_source"/>
                        </group>
                    </group>
                    <group string="Recording">
                        <field name="rc_recording_attachment_id"/>
                    </group>
                    <group string="Agent Notes" invisible="not rc_agent_notes">
                        <field name="rc_agent_notes" nolabel="1"/>
                    </group>
                    <group string="Transcript" invisible="not rc_transcript">
                        <field name="rc_transcript" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
