<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rc_provider_form" model="ir.ui.view">
        <field name="name">rc.sentiment.provider.form</field>
        <field name="model">rc.sentiment.provider</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_provider" string="Test With Sample" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group string="Provider">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="provider_type"/>
                            <field name="is_default"/>
                            <field name="sequence"/>
                        </group>
                        <group string="Authentication">
                            <field name="api_url" placeholder="https://api.example.com/v1/analyze"/>
                            <field name="api_key" password="True"/>
                            <field name="api_model" placeholder="claude-sonnet-4-20250514"/>
                            <field name="timeout"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Webhook Config" invisible="provider_type != 'webhook'">
                            <group string="Headers">
                                <field name="auth_header_name"/>
                                <field name="auth_header_prefix"/>
                                <field name="custom_headers" placeholder='{"X-Custom": "value"}'/>
                            </group>
                            <group string="Request">
                                <field name="request_template" placeholder='{"model":"{{model}}","input":"{{transcript}}"}'/>
                            </group>
                            <group string="Response Parsing">
                                <field name="response_score_path" placeholder="score"/>
                                <field name="response_reason_path" placeholder="reason"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rc_provider_list" model="ir.ui.view">
        <field name="name">rc.sentiment.provider.list</field>
        <field name="model">rc.sentiment.provider</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="provider_type"/>
                <field name="api_url"/>
                <field name="is_default"/>
            </list>
        </field>
    </record>

    <record id="action_rc_provider" model="ir.actions.act_window">
        <field name="name">AI Providers</field>
        <field name="res_model">rc.sentiment.provider</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_rc_providers" name="AI Providers" parent="menu_ringcentral_root"
              action="action_rc_provider" sequence="30" groups="base.group_system"/>
</odoo>
