<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Call History tab to Contact form -->
    <record id="view_partner_form_rc" model="ir.ui.view">
        <field name="name">res.partner.form.ringcentral</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_calls"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-phone"
                        invisible="rc_call_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="rc_call_count"/>
                        </span>
                        <span class="o_stat_text">Calls</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//page[last()]" position="after">
                <page string="Call History" name="rc_calls"
                      invisible="rc_call_count == 0">
                    <group col="4">
                        <field name="rc_call_count" string="Total Calls"/>
                        <field name="rc_last_call" string="Last Call"/>
                        <field name="rc_negative_call_count" string="Negative Calls"/>
                    </group>
                    <field name="rc_call_ids" readonly="1">
                        <list default_order="start_time desc"
                              decoration-danger="sentiment_label == 'negative'"
                              decoration-muted="direction == 'missed'">
                            <field name="name"/>
                            <field name="start_time"/>
                            <field name="direction"/>
                            <field name="duration_display"/>
                            <field name="has_recording" widget="boolean"/>
                            <field name="sentiment_label" widget="badge"
                                   decoration-success="sentiment_label == 'positive'"
                                   decoration-warning="sentiment_label == 'neutral'"
                                   decoration-danger="sentiment_label == 'negative'"/>
                            <field name="ticket_ref"/>
                            <field name="state" widget="badge"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
