<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Configuration Form View -->
    <record id="view_rc_config_form" model="ir.ui.view">
        <field name="name">rc.config.form</field>
        <field name="model">rc.config</field>
        <field name="arch" type="xml">
            <form string="RingCentral Configuration">
                <header>
                    <button name="action_test_connection" string="Test Connection"
                            type="object" class="btn-primary"/>
                    <button name="action_subscribe_webhooks" string="Subscribe Webhooks"
                            type="object" class="btn-secondary"/>
                    <button name="action_unsubscribe_webhooks" string="Unsubscribe Webhooks"
                            type="object" class="btn-secondary" confirm="Remove webhook subscription?"/>
                    <button name="action_manual_sync" string="Sync Now"
                            type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <group string="Connection">
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="rc_server_url"/>
                            <field name="webhook_base_url" placeholder="https://mycompany.odoo.com"/>
                        </group>
                        <group>
                            <field name="rc_client_id" password="True"/>
                            <field name="rc_client_secret" password="True"/>
                            <field name="rc_jwt_token" password="True"/>
                        </group>
                    </group>
                    <group string="Status" col="4">
                        <field name="rc_access_token" password="True"/>
                        <field name="rc_token_expiry"/>
                        <field name="rc_webhook_id"/>
                        <field name="rc_webhook_verification_token" password="True"/>
                    </group>
                    <notebook>
                        <page string="Sentiment &amp; Tickets">
                            <group>
                                <group string="Sentiment Analysis">
                                    <field name="sentiment_provider"/>
                                    <field name="anthropic_api_key" password="True"
                                           invisible="sentiment_provider != 'anthropic'"/>
                                    <field name="sentiment_threshold"/>
                                </group>
                                <group string="Auto-Ticketing">
                                    <field name="auto_create_ticket"/>
                                    <field name="auto_escalate_ticket"/>
                                    <field name="escalation_priority"/>
                                    <field name="helpdesk_team_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Sync Settings">
                            <group>
                                <group>
                                    <field name="sync_recordings"/>
                                    <field name="sync_transcripts"/>
                                </group>
                                <group>
                                    <field name="polling_enabled"/>
                                    <field name="polling_interval"
                                           invisible="not polling_enabled"/>
                                    <field name="last_poll_time"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Configuration Tree View -->
    <record id="view_rc_config_list" model="ir.ui.view">
        <field name="name">rc.config.list</field>
        <field name="model">rc.config</field>
        <field name="arch" type="xml">
            <list string="RingCentral Configurations">
                <field name="company_id"/>
                <field name="rc_server_url"/>
                <field name="rc_webhook_id"/>
                <field name="sentiment_provider"/>
                <field name="polling_enabled"/>
                <field name="last_poll_time"/>
            </list>
        </field>
    </record>

    <!-- Configuration Action -->
    <record id="action_rc_config" model="ir.actions.act_window">
        <field name="name">Configuration</field>
        <field name="res_model">rc.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_ringcentral_root"
              name="RingCentral"
              web_icon="ringcentral_odoo,static/description/icon.png"
              sequence="90"/>

    <menuitem id="menu_rc_config"
              name="Configuration"
              parent="menu_ringcentral_root"
              action="action_rc_config"
              sequence="90"
              groups="group_rc_manager"/>
</odoo>
