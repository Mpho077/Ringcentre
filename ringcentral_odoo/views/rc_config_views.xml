<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_rc_config_form" model="ir.ui.view">
        <field name="name">rc.config.form</field>
        <field name="model">rc.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" string="Test Connection" type="object" class="btn-primary"/>
                    <button name="action_subscribe_webhooks" string="Subscribe Webhooks" type="object"/>
                    <button name="action_manual_sync" string="Sync Now" type="object"/>
                </header>
                <sheet>
                    <group string="RingCentral API">
                        <group>
                            <field name="rc_server_url"/>
                            <field name="rc_client_id" password="True"/>
                            <field name="rc_client_secret" password="True"/>
                            <field name="rc_jwt_token" password="True"/>
                        </group>
                        <group>
                            <field name="webhook_base_url" placeholder="https://your-odoo.com"/>
                            <field name="rc_webhook_id" readonly="1"/>
                            <field name="rc_access_token" password="True" readonly="1"/>
                            <field name="rc_token_expiry" readonly="1"/>
                        </group>
                    </group>
                    <group string="Sync">
                        <group>
                            <field name="sync_recordings"/>
                            <field name="sync_transcripts"/>
                            <field name="polling_enabled"/>
                        </group>
                        <group>
                            <field name="last_poll_time" readonly="1"/>
                        </group>
                    </group>
                    <group string="Ticketing">
                        <group>
                            <field name="auto_create_ticket"/>
                            <field name="auto_escalate_ticket"/>
                        </group>
                        <group>
                            <field name="escalation_priority"/>
                            <field name="sentiment_threshold"/>
                            <field name="helpdesk_team_id"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_rc_config_list" model="ir.ui.view">
        <field name="name">rc.config.list</field>
        <field name="model">rc.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="rc_server_url"/>
                <field name="polling_enabled"/>
            </list>
        </field>
    </record>

    <record id="action_rc_config" model="ir.actions.act_window">
        <field name="name">Configuration</field>
        <field name="res_model">rc.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_rc_config" name="Configuration" parent="menu_ringcentral_root"
              action="action_rc_config" sequence="90" groups="base.group_system"/>
</odoo>
