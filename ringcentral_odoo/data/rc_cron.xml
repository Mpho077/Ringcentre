<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for call log reference -->
        <record id="seq_rc_call_log" model="ir.sequence">
            <field name="name">RingCentral Call Log</field>
            <field name="code">rc.call.log</field>
            <field name="prefix">CALL-</field>
            <field name="padding">6</field>
        </record>

        <!-- Cron: Poll RingCentral for calls (fallback) -->
        <record id="cron_rc_poll_calls" model="ir.cron">
            <field name="name">RingCentral: Poll Call Log</field>
            <field name="model_id" ref="model_rc_call_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_poll_calls()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Cron: Refresh OAuth token -->
        <record id="cron_rc_refresh_token" model="ir.cron">
            <field name="name">RingCentral: Refresh Token</field>
            <field name="model_id" ref="model_rc_config"/>
            <field name="state">code</field>
            <field name="code">
configs = model.search([])
for config in configs:
    try:
        config._refresh_access_token()
    except Exception:
        pass
            </field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

        <!-- Cron: Retry failed call processing -->
        <record id="cron_rc_retry_failed" model="ir.cron">
            <field name="name">RingCentral: Retry Failed Calls</field>
            <field name="model_id" ref="model_rc_call_log"/>
            <field name="state">code</field>
            <field name="code">model._cron_retry_failed()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
