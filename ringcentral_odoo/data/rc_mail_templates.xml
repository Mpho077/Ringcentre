<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_negative_call" model="mail.template">
            <field name="name">RingCentral: Negative Call Alert</field>
            <field name="model_id" ref="model_rc_call_log"/>
            <field name="subject">⚠️ Negative Call Detected — {{ object.partner_id.name or object.caller_number }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; padding: 16px;">
    <h2 style="color: #d32f2f;">⚠️ Negative Call Sentiment Detected</h2>

    <table style="border-collapse: collapse; width: 100%; max-width: 500px;">
        <tr>
            <td style="padding: 8px; font-weight: bold;">Call Reference:</td>
            <td style="padding: 8px;">{{ object.name }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; font-weight: bold;">Contact:</td>
            <td style="padding: 8px;">{{ object.partner_id.name or 'Unknown' }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; font-weight: bold;">Phone:</td>
            <td style="padding: 8px;">{{ object.caller_number }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; font-weight: bold;">Sentiment Score:</td>
            <td style="padding: 8px; color: #d32f2f; font-weight: bold;">{{ '%.2f' % object.sentiment_score }}</td>
        </tr>
        <tr>
            <td style="padding: 8px; font-weight: bold;">Duration:</td>
            <td style="padding: 8px;">{{ object.duration_display }}</td>
        </tr>
    </table>

    {% if object.ticket_ref %}
    <p style="margin-top: 16px;">
        <strong>Helpdesk Ticket Created:</strong> {{ object.ticket_ref }}
    </p>
    {% endif %}

    {% if object.transcript %}
    <div style="margin-top: 16px; padding: 12px; background: #f5f5f5; border-radius: 4px;">
        <strong>Transcript Preview:</strong>
        <pre style="white-space: pre-wrap; font-size: 13px;">{{ object.transcript[:1000] }}</pre>
    </div>
    {% endif %}
</div>
            ]]></field>
        </record>
    </data>
</odoo>
