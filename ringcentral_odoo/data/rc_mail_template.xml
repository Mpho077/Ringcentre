<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="mail_template_negative_call" model="mail.template">
            <field name="name">RingCentral: Negative Call Alert</field>
            <field name="model_id" ref="model_rc_call_log"/>
            <field name="subject">Negative Call Detected — {{ object.partner_id.name or object.caller_number }}</field>
            <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; padding: 16px;">
    <h2 style="color: #d32f2f;">Negative Call Sentiment Detected</h2>
    <table style="border-collapse: collapse; max-width: 500px;">
        <tr><td style="padding: 8px; font-weight: bold;">Call:</td><td style="padding: 8px;">{{ object.name }}</td></tr>
        <tr><td style="padding: 8px; font-weight: bold;">Contact:</td><td style="padding: 8px;">{{ object.partner_id.name or 'Unknown' }}</td></tr>
        <tr><td style="padding: 8px; font-weight: bold;">Phone:</td><td style="padding: 8px;">{{ object.caller_number }}</td></tr>
        <tr><td style="padding: 8px; font-weight: bold;">Score:</td><td style="padding: 8px; color: #d32f2f;">{{ '%.2f' % object.sentiment_score }}</td></tr>
        <tr><td style="padding: 8px; font-weight: bold;">Duration:</td><td style="padding: 8px;">{{ object.duration_display }}</td></tr>
    </table>
    {% if object.ticket_ref %}
    <p style="margin-top: 16px;"><strong>Ticket:</strong> {{ object.ticket_ref }}</p>
    {% endif %}
</div>
            ]]></field>
        </record>
    </data>
</odoo>
