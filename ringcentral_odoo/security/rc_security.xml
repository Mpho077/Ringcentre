<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- User Group -->
    <record id="group_rc_user" model="res.groups">
        <field name="name">RingCentral User</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Manager Group -->
    <record id="group_rc_manager" model="res.groups">
        <field name="name">RingCentral Manager</field>
        <field name="implied_ids" eval="[(4, ref('group_rc_user'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="rule_rc_call_log_company" model="ir.rule">
        <field name="name">Call Log: Company Rule</field>
        <field name="model_id" ref="model_rc_call_log"/>
        <field name="domain_force">[('create_uid.company_id', '=', user.company_id.id)]</field>
        <field name="groups" eval="[(4, ref('group_rc_user'))]"/>
    </record>

    <record id="rule_rc_call_log_manager" model="ir.rule">
        <field name="name">Call Log: Manager Full Access</field>
        <field name="model_id" ref="model_rc_call_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_rc_manager'))]"/>
    </record>
</odoo>
